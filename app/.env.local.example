# TxLINE devnet credentials (server-side only — never exposed to the browser).
# For local dev you can instead drop the bootstrap output at ../txline/credentials.json
# and these can be left unset; lib/txlineServer.ts falls back to that file.
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
TXLINE_JWT=your_guest_jwt
TXLINE_API_TOKEN=your_api_token
